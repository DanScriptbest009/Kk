button.MouseButton1Click:Connect(function()
    if menu.Visible then
        TweenService:Create(menu, TweenInfo.new(0.12), {BackgroundTransparency = 1}):Play()
        task.wait(0.08)
        menu.Visible = false
    else
        local buttonPos = button.AbsolutePosition
        local buttonSize = button.AbsoluteSize
        local menuSize = menu.AbsoluteSize
        local screenSize = screenGui.AbsoluteSize
        
        local targetX = buttonPos.X - menuSize.X - 8
        if targetX < 0 then
            targetX = buttonPos.X + buttonSize.X + 8
        end
        if targetX + menuSize.X > screenSize.X then
            targetX = screenSize.X - menuSize.X - 5
        end
        
        local targetY = buttonPos.Y - 20
        if targetY < 5 then
            targetY = 5
        end
        if targetY + menuSize.Y > screenSize.Y then
            targetY = screenSize.Y - menuSize.Y - 5
        end
        
        menu.Position = UDim2.new(0, targetX, 0, targetY)
        menu.BackgroundTransparency = 1
        menu.Visible = true
        TweenService:Create(menu, TweenInfo.new(0.18, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {BackgroundTransparency = 0.03}):Play()
        
        local bounceTween = TweenService:Create(menu, TweenInfo.new(0.08, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, targetX + 2, 0, targetY + 2)
        })
        bounceTween:Play()
        bounceTween.Completed:Connect(function()
            TweenService:Create(menu, TweenInfo.new(0.04), {
                Position = UDim2.new(0, targetX, 0, targetY)
            }):Play()
        end)
    end
end)

