local function getLocalTeam()
    local playerGui = player:FindFirstChildOfClass("PlayerGui")
    if not playerGui then return nil end
    local main = playerGui:FindFirstChild("Main")
    if not main then return nil end
    local mainGameFrame = main:FindFirstChild("MainGameFrame")
    if not mainGameFrame then return nil end
    local playersFrame = mainGameFrame:FindFirstChild("PlayersFrame")
    if not playersFrame then return nil end
    
    local teamRed = playersFrame:FindFirstChild("TeamRedFrame")
    local teamBlue = playersFrame:FindFirstChild("TeamBlueFrame")
    
    if teamRed and teamRed:FindFirstChild(player.Name) then
        return "Red"
    elseif teamBlue and teamBlue:FindFirstChild(player.Name) then
        return "Blue"
    end
    return nil
end

local function refreshLocalTeam()
    localTeamCache = getLocalTeam()
    return localTeamCache
end

local function isEnemy(targetPlayer)
    if localTeamCache == nil then
        refreshLocalTeam()
    end
    
    if localTeamCache == nil then return true end
    
    local playerGui = player:FindFirstChildOfClass("PlayerGui")
    if not playerGui then return true end
    local main = playerGui:FindFirstChild("Main")
    if not main then return true end
    local mainGameFrame = main:FindFirstChild("MainGameFrame")
    if not mainGameFrame then return true end
    local playersFrame = mainGameFrame:FindFirstChild("PlayersFrame")
    if not playersFrame then return true end
    
    local teamRed = playersFrame:FindFirstChild("TeamRedFrame")
    local teamBlue = playersFrame:FindFirstChild("TeamBlueFrame")
    
    local targetName = targetPlayer.Name
    
    if localTeamCache == "Red" then
        if teamBlue and teamBlue:FindFirstChild(targetName) then
            return true
        end
        return false
    elseif localTeamCache == "Blue" then
        if teamRed and teamRed:FindFirstChild(targetName) then
            return true
        end
        return false
    end
    
    return true
end

local function getCurrentGun()
    local char = player.Character
    if not char then return nil end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool:FindFirstChild("Handle") then
            return tool
        end
    end
    return nil
end

local function isEnemyInFront(enemyChar)
    local myChar = player.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") or not myChar:FindFirstChild("Head") then return false end
    if not enemyChar or not enemyChar:FindFirstChild("HumanoidRootPart") then return false end
    local myRoot = myChar.HumanoidRootPart
    local enemyRoot = enemyChar.HumanoidRootPart
    local directionToEnemy = (enemyRoot.Position - myRoot.Position).Unit
    local lookDirection = Camera.CFrame.LookVector
    local dot = directionToEnemy:Dot(lookDirection)
    return dot > 0.1
end

local function getClosestEnemyInFront()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myRoot = char.HumanoidRootPart
    local origin = char:FindFirstChild("Head") and char.Head.Position or myRoot.Position
    local closest = nil
    local bestDist = math.huge
    for _, p in Players:GetPlayers() do
        if p ~= player and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 and isEnemy(p) then
            local enemyChar = p.Character
            local torso = enemyChar:FindFirstChild("HumanoidRootPart") or enemyChar:FindFirstChild("Torso") or enemyChar:FindFirstChild("UpperTorso")
            if torso and isEnemyInFront(enemyChar) then
                local dist = (torso.Position - myRoot.Position).Magnitude
                if dist < bestDist then
                    local dir = torso.Position - origin
                    local params = RaycastParams.new()
                    params.FilterDescendantsInstances = {char}
                    params.FilterType = Enum.RaycastFilterType.Exclude
                    local result = Workspace:Raycast(origin, dir * 1000, params)
                    if not result or result.Instance:IsDescendantOf(enemyChar) then
                        bestDist = dist
                        closest = p
                    end
                end
            end
        end
    end
    return closest
end

local function getClosestEnemyAnywhere()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myRoot = char.HumanoidRootPart
    local closest = nil
    local bestDist = math.huge
    for _, p in Players:GetPlayers() do
        if p ~= player and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 and isEnemy(p) then
            local enemyChar = p.Character
            local torso = enemyChar:FindFirstChild("HumanoidRootPart") or enemyChar:FindFirstChild("Torso") or enemyChar:FindFirstChild("UpperTorso")
            if torso then
                local dist = (torso.Position - myRoot.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    closest = p
                end
            end
        end
    end
    return closest
end

local function perfectTorsoShot()
    if not perfectShootEnabled then return end
    local gun = getCurrentGun()
    if not gun then return end
    local target = getClosestEnemyInFront()
    if not target or not target.Character then return end
    local torso = target.Character:FindFirstChild("HumanoidRootPart") or target.Character:FindFirstChild("Torso") or target.Character:FindFirstChild("UpperTorso")
    if not torso then return end
    local handle = gun:FindFirstChild("Handle")
    if not handle then return end
    local barrel = gun:FindFirstChild("Barrel") or handle:FindFirstChild("Barrel") or handle:FindFirstChild("Muzzle") or handle:FindFirstChildWhichIsA("Attachment") or handle
    local muzzlePos = barrel.Position
    local targetPos = torso.Position
    local fire = gun:FindFirstChild("fire")
    if fire then pcall(function() fire:FireServer() end) end
    local beam = gun:FindFirstChild("showBeam")
    if beam then pcall(function() beam:FireServer(targetPos, muzzlePos, handle) end) end
    local kill = gun:FindFirstChild("kill")
    if kill then pcall(function() kill:FireServer(target) end) end
end

local function autoTorsoShoot()
    if not autoShootEnabled then return end
    
    local gun = getCurrentGun()
    if not gun then return end

    local target = getClosestEnemyInFront()

    if target and target.Character then
        if not isEnemy(target) then return end
        
        if lastTarget ~= target then
            lastTarget = target
            shootTime = tick() + autoShootDelay
        end

        if tick() >= shootTime then
            local torso = target.Character:FindFirstChild("HumanoidRootPart") or 
                         target.Character:FindFirstChild("UpperTorso") or 
                         target.Character:FindFirstChild("Torso")
            if torso then
                local handle = gun:FindFirstChild("Handle")
                if handle then
                    local barrel = gun:FindFirstChild("Barrel") or handle:FindFirstChild("Barrel") or 
                                  handle:FindFirstChild("Muzzle") or handle:FindFirstChildWhichIsA("Attachment") or handle

                    local fire = gun:FindFirstChild("fire")
                    if fire then pcall(function() fire:FireServer() end) end
                    local beam = gun:FindFirstChild("showBeam")
                    if beam then pcall(function() beam:FireServer(torso.Position, barrel.Position, handle) end) end
                    local kill = gun:FindFirstChild("kill")
                    if kill then pcall(function() kill:FireServer(target) end) end

                    shootTime = tick() + autoShootDelay
                end
            end
        end
    else
        lastTarget = nil
    end
end

local function connectGun(tool)
    if tool:IsA("Tool") then
        tool.Activated:Connect(function()
            if perfectShootEnabled then
                task.spawn(perfectTorsoShot)
            end
        end)
    end
end

player.CharacterAdded:Connect(function(char)
    char.ChildAdded:Connect(connectGun)
    for _, tool in char:GetChildren() do
        connectGun(tool)
    end
end)

if player.Character then
    for _, tool in player.Character:GetChildren() do
        connectGun(tool)
    end
end

task.spawn(function()
    while true do
        if instaKillEnabled then
            local cachedRemotes = {}
            local areas = {ReplicatedStorage, workspace, player.Backpack}
            
            for _, area in pairs(areas) do
                pcall(function()
                    for _, obj in ipairs(area:GetDescendants()) do
                        if obj:IsA("RemoteEvent") and (obj.Name:lower():find("kill") or obj.Name:lower():find("knife")) then
                            table.insert(cachedRemotes, obj)
                        end
                    end
                end)
            end
            
            if #cachedRemotes > 0 then
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
                        for _, remote in pairs(cachedRemotes) do
                            pcall(function()
                                remote:FireServer(v.Character)
                                remote:FireServer(v)
                                remote:FireServer(v.Character.Humanoid)
                                remote:FireServer()
                            end)
                        end
                        task.wait(0.0001)
                    end
                end
            end
        end
        task.wait(0.0001)
    end
end)

