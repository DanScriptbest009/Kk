local function animateButton(btn, isActive)
    local originalSize = btn.Size
    local scaleSize = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, originalSize.Y.Scale, originalSize.Y.Offset * 0.93)
    local tween1 = TweenService:Create(btn, TweenInfo.new(0.06, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = scaleSize})
    tween1:Play()
    tween1.Completed:Connect(function()
        local tween2 = TweenService:Create(btn, TweenInfo.new(0.06, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out), {Size = originalSize})
        tween2:Play()
    end)
end

local function createToggle(text, yPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 32)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(90, 60, 140)
    btn.Text = "  " .. text .. "  OFF"
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.ZIndex = 12
    btn.AutoButtonColor = false
    btn.Parent = menu
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 7)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(180, 90, 255)
    stroke.Thickness = 1.5
    stroke.Transparency = 0.25
    stroke.Parent = btn
    
    local btnGlowImg = Instance.new("ImageLabel")
    btnGlowImg.Size = UDim2.new(1.06, 0, 1.4, 0)
    btnGlowImg.Position = UDim2.new(-0.03, 0, -0.2, 0)
    btnGlowImg.BackgroundTransparency = 1
    btnGlowImg.Image = "rbxassetid://13135718668"
    btnGlowImg.ImageColor3 = Color3.fromRGB(180, 100, 255)
    btnGlowImg.ImageTransparency = 0.8
    btnGlowImg.ZIndex = 11
    btnGlowImg.Visible = false
    btnGlowImg.Parent = btn
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(110, 80, 160)}):Play()
        btnGlowImg.Visible = true
        TweenService:Create(btnGlowImg, TweenInfo.new(0.2), {ImageTransparency = 0.45}):Play()
    end)
    
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(90, 60, 140)}):Play()
        TweenService:Create(btnGlowImg, TweenInfo.new(0.2), {ImageTransparency = 0.8}):Play()
        task.wait(0.2)
        btnGlowImg.Visible = false
    end)
    
    return btn, stroke
end

