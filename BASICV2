local function storeOriginalHitbox(player)
    if not originalHitboxSizes[player] and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        originalHitboxSizes[player] = {
            Size = hrp.Size,
            Transparency = hrp.Transparency,
            Color = hrp.Color,
            Material = hrp.Material,
            CanCollide = hrp.CanCollide
        }
    end
end

local function restoreOriginalHitbox(player)
    if originalHitboxSizes[player] and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        local original = originalHitboxSizes[player]
        hrp.Size = original.Size
        hrp.Transparency = original.Transparency
        hrp.Color = original.Color
        hrp.Material = original.Material
        hrp.CanCollide = original.CanCollide
        originalHitboxSizes[player] = nil
    end
end

local function updateHitboxPlayers()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and not table.find(affectedPlayers, v) then
            if v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                table.insert(affectedPlayers, v)
                if hitboxEnabled then
                    storeOriginalHitbox(v)
                end
            end
        end
    end
    
    for i = #affectedPlayers, 1, -1 do
        local v = affectedPlayers[i]
        if not v.Parent or not v.Character or not v.Character:FindFirstChild("HumanoidRootPart") then
            if hitboxEnabled then
                restoreOriginalHitbox(v)
            end            table.remove(affectedPlayers, i)
        end
    end
end

local function applyHitbox()
    if not hitboxEnabled then return end
    
    for _, v in pairs(affectedPlayers) do
        if v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local humanoid = v.Character:FindFirstChild("Humanoid")
            
            if humanoid and humanoid.Health > 0 then
                if not originalHitboxSizes[v] then
                    storeOriginalHitbox(v)
                end
                
                local newSize = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                if hrp.Size ~= newSize then
                    hrp.Size = newSize
                end
                
                hrp.Transparency = 0.5
                hrp.Color = Color3.fromRGB(0, 100, 255)
                hrp.Material = Enum.Material.Neon
                hrp.CanCollide = false
            elseif originalHitboxSizes[v] then
                restoreOriginalHitbox(v)
            end
        end
    end
end

local function enableHitbox()
    if hitboxEnabled then return end
    hitboxEnabled = true
    hitboxBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 50)
    hitboxBtn.Text = " ON"
    animateButton(hitboxBtn, true)
    
    updateHitboxPlayers()
    
    for _, v in pairs(affectedPlayers) do
        storeOriginalHitbox(v)
    end
    
    applyHitbox()
end

local function disableHitbox()
    if not hitboxEnabled then return end
    hitboxEnabled = false
    hitboxBtn.BackgroundColor3 = Color3.fromRGB(90, 60, 140)
    hitboxBtn.Text = " OFF"
    animateButton(hitboxBtn, false)
    
    for _, v in pairs(affectedPlayers) do
        restoreOriginalHitbox(v)
    end
end

local function setHitboxSize(newSize)
    local clampedSize = math.clamp(newSize, 1, 50)
    if hitboxSize == clampedSize then return end
    
    hitboxSize = clampedSize
    sliderFill.Size = UDim2.new((hitboxSize - 1) / 49, 0, 1, 0)
    hitboxValueInput.Text = tostring(hitboxSize)
    sizeLabel.Text = "Size: " .. hitboxSize
    
    if hitboxEnabled then
        applyHitbox()
    end
end

